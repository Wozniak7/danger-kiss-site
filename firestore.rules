rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite leitura pública para shows e conteúdo
    match /shows/{show} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /content/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Proteção genérica
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
